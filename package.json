{
  "name": "templates.bun",
  "version": "0.1.0",
  "description": "Minimal Bun starter with TypeScript, Prettier, and tests.",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "files": [
    "src"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.3",
  "license": "MIT",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist",
    "format": "bunx prettier --write .",
    "typecheck": "bunx tsc --noEmit",
    "check": "bunx prettier --check . && bun run typecheck && bun run test",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
